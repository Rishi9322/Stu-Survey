{
    "name": "stu/survey",
    "description": "Student Satisfaction Survey System",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "tecnickcom/tcpdf": "^6.10",
        "php-webdriver/webdriver": "^1.1",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpmd/phpmd": "^2.15",
        "codeception/codeception": "^5.1",
        "codeception/module-phpbrowser": "^3.0",
        "codeception/module-asserts": "^3.0",
        "codeception/module-db": "^3.1",
        "codeception/module-rest": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/",
            "Database\\": "database/",
            "Tests\\": "tests/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/codecept run",
        "test:unit": "vendor/bin/codecept run unit",
        "test:functional": "vendor/bin/codecept run functional",
        "test:acceptance": "vendor/bin/codecept run acceptance"
    }
}
