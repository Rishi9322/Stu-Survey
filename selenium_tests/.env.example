# Selenium Test Configuration

# Base URLs - Apache/PHP running on port 80
# XAMPP Server Configuration
BASE_URL=http://localhost/stu/public
PHP_API_URL=http://localhost/stu/api

# Database Configuration - MySQL on port 3306
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=student_feedback

# Test User Credentials (for authentication tests)
TEST_EMAIL=testuser@example.com
TEST_PASSWORD=TestPassword123!

# Chrome/WebDriver Options
HEADLESS=false
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Selenium Configuration
IMPLICIT_WAIT=10
EXPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30

# Test Reporting
REPORT_DIR=./reports
REPORT_FORMAT=html

# Logging
LOG_LEVEL=INFO
